-- SNOW
local snowParts = {}
coroutine.wrap(function()
    while task.wait(0.3) do
        if Settings.Visuals.Snow then
            for i = #snowParts, 1, -1 do
                if snowParts[i] and snowParts[i].Parent then
                    snowParts[i].CFrame = snowParts[i].CFrame + Vector3.new(0, -0.3, 0)
                    if snowParts[i].Position.Y < 0 then snowParts[i]:Destroy(); table.remove(snowParts, i) end
                end
            end
            for i = 1, Settings.Visuals.SnowAmount do
                local part = Instance.new("Part")
                part.Size = Vector3.new(0.2, 0.2, 0.2)
                part.BrickColor = BrickColor.new("White")
                part.Material = Enum.Material.Neon
                part.CFrame = CFrame.new(math.random(-Settings.Visuals.SnowRadius, Settings.Visuals.SnowRadius), 30, math.random(-Settings.Visuals.SnowRadius, Settings.Visuals.SnowRadius))
                part.Anchored = true
                part.CanCollide = false
                part.Parent = workspace
                table.insert(snowParts, part)
            end
        else
            for _, part in ipairs(snowParts) do if part and part.Parent then part:Destroy() end end
            snowParts = {}
        end
    end
end)()

-- JUMP CIRCLES
coroutine.wrap(function()
